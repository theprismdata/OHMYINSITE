{
  "name": "ohmyinsite",
  "version": "0.0.1",
  "description": "OHMYINSITE - Executive Technical Document RAG Assistant",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron .",
    "dev": "electron .",
    "mcp-server": "tsc -p tsconfig.json && node dist/mcp-server.js",
    "mcp-server:dev": "node dist/mcp-server.js",
    "dist:mac": "npm run build && electron-builder --mac dmg --arm64 --config.directories.output=release-mac",
    "dist:dmg": "npm run dist:mac",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --config.directories.output=release-win"
  },
  "author": "theprismdata",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.theprismdata.ohmyinsite",
    "productName": "OHMYINSITE",
    "files": [
      "dist/**/*",
      "index.html",
      "package.json",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "mac": {
      "icon": "assets/icon/icon.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false
    },
    "win": {
      "icon": "assets/icon/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "installerIcon": "assets/icon/icon.ico",
      "uninstallerIcon": "assets/icon/icon.ico"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "cfb": "^1.2.2",
    "dotenv": "^17.3.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "openai": "^4.0.0",
    "pako": "^2.1.0",
    "pdf-parse": "^2.4.5"
  }
}
