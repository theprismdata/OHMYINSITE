# App branding
APP_TITLE=OHMYINSITE

# Dify
DIFY_MODE=false
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=app-your-dify-api-key
# Optional session fallback for Dify
DIFY_SESSION_TOKEN=

# OpenAI (required when using GPT provider)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (required when using Claude provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# Optional session fallback for Anthropic
ANTHROPIC_SESSION_TOKEN=

# Optional custom OpenAI-compatible endpoint (off by default)
OPENAI_USE_CUSTOM_BASE_URL=false
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=

# External web search for google_search tool
# Priority 1: SerpAPI
SERPAPI_KEY=
# Priority 2: Google CSE (used only when SERPAPI_KEY is empty)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# MCP server
MCP_PORT=8001

# Chat timeout in milliseconds
CHAT_REQUEST_TIMEOUT_MS=90000

# SSH tool (optional)
# Comma-separated allowlist. Empty means allow all hosts.
SSH_ALLOWED_HOSTS=
# Default timeout for ssh_exec tool
SSH_DEFAULT_TIMEOUT_MS=20000

# Docker tools (optional)
# Docker CLI path
DOCKER_BIN=docker
# Default timeout for docker_ps/docker_logs/docker_exec
DOCKER_DEFAULT_TIMEOUT_MS=20000
# Comma-separated allowlist. Empty means allow all containers.
DOCKER_ALLOWED_CONTAINERS=
